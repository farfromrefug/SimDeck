{
  "name": "@nativescript/simdeck-inspector",
  "version": "0.1.5",
  "description": "Debug-only NativeScript runtime inspector for simdeck",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NativeScript/SimDeck",
    "directory": "packages/nativescript-inspector"
  },
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "node ./scripts/clean.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md",
    "src"
  ],
  "keywords": [
    "nativescript",
    "uikit",
    "inspector",
    "simdeck"
  ],
  "sideEffects": false,
  "nativescript": {
    "platforms": {
      "ios": "9.0.0"
    }
  },
  "peerDependencies": {
    "@nativescript/angular": ">=18.0.0",
    "@nativescript/core": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@nativescript/angular": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nativescript/core": "~9.0.0",
    "typescript": "~5.8.0"
  }
}
